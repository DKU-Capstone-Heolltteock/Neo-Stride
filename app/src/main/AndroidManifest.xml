<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NeoStride"
        android:usesCleartextTraffic="true">

        <!-- 팁 상세 액티비티 -->
        <activity
            android:name=".feature.community.tip.TipDetailActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- 피드 상세 액티비티 -->
        <activity
            android:name=".feature.community.feed.FeedDetailActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- 팁 업로드 시 기록 선택 액티비티 -->
        <activity
            android:name=".feature.community.tip.TipRecordSelectActivity"
            android:exported="false" />

        <!-- 인증 관련 액티비티 -->
        <activity
            android:name=".feature.auth.FindIdSuccessActivity"
            android:exported="false" />

        <activity
            android:name=".feature.auth.FindIdCodeVerifyActivity"
            android:exported="false" />

        <activity
            android:name=".feature.auth.FindIdActivity"
            android:exported="false" />

        <activity
            android:name=".feature.auth.ResetSuccessActivity"
            android:exported="false" />

        <activity
            android:name=".feature.auth.NewPasswordActivity"
            android:exported="false" />

        <activity
            android:name=".feature.auth.ResetCodeVerifyActivity"
            android:exported="false" />

        <activity
            android:name=".feature.auth.ResetPasswordActivity"
            android:exported="false" />

        <activity
            android:name=".feature.auth.SuccessActivity"
            android:exported="false" />

        <activity
            android:name=".feature.auth.CodeVerifyActivity"
            android:exported="false" />

        <activity
            android:name=".feature.auth.EmailAuthActivity"
            android:exported="false" />

        <activity
            android:name=".feature.auth.SignupActivity"
            android:exported="false" />

        <!-- 로그인 액티비티: 앱 실행 시 첫 화면 -->
        <activity
            android:name=".feature.auth.LoginActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 메인 액티비티 -->
        <activity
            android:name=".feature.main.MainActivity"
            android:exported="false" />

        <!-- 커뮤니티 액티비티 -->
        <activity
            android:name=".feature.community.CommunityActivity"
            android:exported="false" />

        <!-- 팁 업로드 액티비티 -->
        <activity
            android:name=".feature.community.tip.TipUploadActivity"
            android:exported="false"
            android:theme="@style/Theme.NeoStride.TipUploadDialog" />

        <!-- 패치노트 상세 액티비티 -->
        <activity
            android:name=".feature.community.event.PatchNoteDetailActivity"
            android:exported="false" />

        <!-- 마이페이지 액티비티 -->
        <activity
            android:name=".feature.community.mypage.MyPageActivity"
            android:exported="false" />

        <!-- 알림 액티비티 -->
        <activity
            android:name=".feature.notification.NotificationActivity"
            android:exported="false" />

        <!-- 뱃지 액티비티 -->
        <activity
            android:name=".feature.badge.BadgeActivity"
            android:exported="false" />

        <!-- 친구 액티비티 -->
        <activity
            android:name=".feature.community.friend.FriendActivity"
            android:exported="false" />

        <!-- 러너페이지 액티비티 -->
        <activity
            android:name=".feature.community.runnerpage.RunnerPageActivity"
            android:exported="false" />

        <!-- 계정 액티비티 -->
        <activity
            android:name=".feature.account.AccountActivity"
            android:exported="false" />

        <!-- 러너 친구 목록 액티비티 -->
        <activity
            android:name=".feature.community.friend.RunnerFriendListActivity"
            android:exported="false" />

        <!-- GPS 포그라운드 서비스: 화면 꺼져도 기록 유지 -->
        <service
            android:name=".feature.main.running.LocationTrackingService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- Google Maps API 키 -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyBK52DjufNEbeLsSf4cVNO3UIq5ZeJb2RQ" />

    </application>

</manifest>