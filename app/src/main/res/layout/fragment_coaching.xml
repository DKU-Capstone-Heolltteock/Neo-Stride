<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <View android:layout_width="match_parent" android:layout_height="100dp" />

    <!-- 월 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/btn_prev_week"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_left"
            app:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true" android:focusable="true" />

        <TextView
            android:id="@+id/tv_week_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="2026년 4월"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_next_week"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_right"
            app:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>

    <!-- 주간 날짜 (스와이프 가능) -->
    <com.neostride.app.feature.coaching.SwipeDetector
        android:id="@+id/layout_week_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="8dp" />

    <!-- 오늘로 돌아가기 -->
    <TextView
        android:id="@+id/btn_today"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:layout_gravity="center"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:text="오늘로"
        android:textColor="#000000"
        android:textSize="12sp"
        android:textStyle="bold"
        android:background="@drawable/btn_period_selected"
        android:clickable="true" android:focusable="true"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A1A"
        android:layout_marginHorizontal="20dp" />

    <!-- 메인 컨텐츠 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp">

            <!-- 새 목표 버튼 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_add_goal"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:clickable="true" android:focusable="true"
                android:visibility="visible"
                app:cardBackgroundColor="#CCFF00"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="＋ 새 목표 설정"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <!-- 플랜 없을 때 -->
            <TextView
                android:id="@+id/tv_no_plan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="이 날짜에 설정된 목표가 없습니다"
                android:textColor="#555555"
                android:textSize="14sp"
                android:gravity="center"
                android:paddingTop="20dp"
                android:visibility="visible" />

            <!-- 플랜 상세 (인라인) -->
            <LinearLayout
                android:id="@+id/layout_plan_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- 플랜 제목 카드 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tv_plan_title"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="#FF9500"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tv_plan_status"
                                android:layout_width="wrap_content"
                                android:layout_height="26dp"
                                android:gravity="center"
                                android:paddingHorizontal="12dp"
                                android:textColor="#FF9500"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:background="@drawable/btn_status_bg" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_plan_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp"
                            android:layout_marginTop="6dp"
                            android:fontFamily="sans-serif" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- your set 카드 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <View
                                android:id="@+id/view_your_set_dot"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/bg_calendar_pending"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="your set."
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                            <androidx.cardview.widget.CardView
                                android:id="@+id/btn_delete_goal"
                                android:layout_width="wrap_content"
                                android:layout_height="30dp"
                                android:clickable="true" android:focusable="true"
                                app:cardBackgroundColor="#2A1515"
                                app:cardCornerRadius="15dp"
                                app:cardElevation="0dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:paddingHorizontal="14dp"
                                    android:text="삭제"
                                    android:textColor="#FF6666"
                                    android:textSize="12sp"
                                    android:fontFamily="sans-serif-medium" />
                            </androidx.cardview.widget.CardView>
                        </LinearLayout>

                        <TextView android:id="@+id/tv_set_period" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#999999" android:textSize="13sp" android:paddingStart="16dp" android:layout_marginBottom="3dp" android:fontFamily="sans-serif" />
                        <TextView android:id="@+id/tv_set_days" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#999999" android:textSize="13sp" android:paddingStart="16dp" android:layout_marginBottom="3dp" android:fontFamily="sans-serif" />
                        <TextView android:id="@+id/tv_set_distance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#999999" android:textSize="13sp" android:paddingStart="16dp" android:layout_marginBottom="3dp" android:fontFamily="sans-serif" />
                        <TextView android:id="@+id/tv_set_pace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#999999" android:textSize="13sp" android:paddingStart="16dp" android:fontFamily="sans-serif" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- AI feedback 카드 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/bg_calendar_pending"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AI feedback"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_ai_feedback"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="아직 피드백이 없습니다."
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:lineSpacingExtra="4dp"
                            android:fontFamily="sans-serif" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- 과거 목표 목록 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_toggle_history"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:clickable="true" android:focusable="true"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_coaching_history"
                            app:tint="#CCFF00"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="과거 목표 목록"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <ImageView
                            android:id="@+id/iv_history_arrow"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="#CCFF00" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tv_history_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="히스토리가 없습니다"
                    android:textColor="#444444"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingVertical="16dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>