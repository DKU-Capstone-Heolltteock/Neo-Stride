<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <View android:layout_width="match_parent" android:layout_height="100dp" />

    <TextView
        android:id="@+id/tv_week_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="2026년 5월"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingVertical="12dp"
        android:paddingHorizontal="24dp"
        android:clickable="true"
        android:focusable="true" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vp_week"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/btn_today"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:layout_gravity="center"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:text="오늘로"
        android:textColor="#CCFF00"
        android:textSize="12sp"
        android:textStyle="bold"
        android:background="@drawable/bg_detail_btn"
        android:clickable="true" android:focusable="true"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A1A"
        android:layout_marginHorizontal="20dp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="140dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/btn_add_goal"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:clickable="true" android:focusable="true"
                android:visibility="visible"
                app:cardBackgroundColor="#CCFF00"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="＋ 새 목표 설정"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_no_plan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="이 날짜에 설정된 목표가 없습니다"
                android:textColor="#555555"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="20dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_card_bordered"
                android:visibility="visible" />

            <!-- ═══ 통합 카드 (Training + your set + AI feedback) ═══ -->
            <LinearLayout
                android:id="@+id/layout_plan_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/card_plan_main"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_bordered"
                    android:padding="18dp"
                    android:layout_marginBottom="8dp">

                    <!-- Training Routine 제목 영역 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:id="@+id/tv_plan_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="#FF9500"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:id="@+id/tv_plan_status"
                            android:layout_width="wrap_content"
                            android:layout_height="26dp"
                            android:gravity="center"
                            android:paddingHorizontal="12dp"
                            android:textColor="#FF9500"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_plan_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif" />

                    <!-- 🌟 1. AI 미션 정보 바구니 (서버 데이터가 있을 때만 자바에서 VISIBLE 처리) -->
                    <LinearLayout
                        android:id="@+id/layout_daily_mission_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <!-- 목표 거리 달성 여부 -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="10dp">
                            <ImageView
                                android:id="@+id/iv_distance_status"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_just_circle"
                                android:layout_marginEnd="6dp" />
                            <TextView
                                android:id="@+id/tv_distance_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#CCCCCC"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif" />
                        </LinearLayout>

                        <!-- 목표 페이스 달성 여부 -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">
                            <ImageView
                                android:id="@+id/iv_pace_status"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_just_circle"
                                android:layout_marginEnd="6dp" />
                            <TextView
                                android:id="@+id/tv_pace_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#CCCCCC"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif" />
                        </LinearLayout>
                    </LinearLayout>

                    <!--  2. AI 미션이 없을 때 보여줄 안내 문구 (서버 데이터가 없을 때 자바에서 VISIBLE 처리) -->
                    <TextView
                        android:id="@+id/tv_no_mission_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:fontFamily="sans-serif"
                        android:visibility="gone"
                        android:text="AI 목표를 준비 중입니다." />

                    <!-- 훈련 완료 배너 (completed일 때만 표시) -->
                    <LinearLayout
                        android:id="@+id/layout_done_banner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_done_banner"
                        android:padding="10dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_running_done"
                            app:tint="#CCFF00"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="This Day's Training has been done"
                            android:textColor="#CCFF00"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/btn_view_detail"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:gravity="center"
                            android:paddingHorizontal="10dp"
                            android:text="상세 기록 확인"
                            android:textColor="#CCFF00"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_detail_btn"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <!-- 구분선 1 -->
                    <View android:id="@+id/divider_1" android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333" android:layout_marginVertical="14dp" />

                    <!-- AI feedback (위로 이동) -->
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <ImageView
                            android:id="@+id/iv_ai_feedback_icon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_coaching_ai_feedback"
                            android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI Feedback" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <TextView android:id="@+id/tv_ai_feedback" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="아직 피드백이 없습니다." android:textColor="#888888" android:textSize="13sp" android:lineSpacingExtra="4dp" android:fontFamily="sans-serif" />

                    <!-- 구분선 2 -->
                    <View android:id="@+id/divider_2" android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333" android:layout_marginVertical="14dp" />

                    <!-- Your Setting (아래로 이동) -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <ImageView
                            android:id="@+id/iv_your_set_icon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_coaching_yourset"
                            android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Your Setting" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                        <LinearLayout
                            android:id="@+id/btn_delete_goal"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:gravity="center"
                            android:paddingHorizontal="14dp"
                            android:clickable="true" android:focusable="true"
                            android:background="@drawable/bg_card_bordered">
                            <TextView
                                android:id="@+id/tv_delete_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="삭제"
                                android:textColor="#FF6666"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView android:id="@+id/tv_set_period" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#999999" android:textSize="13sp" android:paddingStart="28dp" android:layout_marginBottom="3dp" android:fontFamily="sans-serif" />
                    <TextView android:id="@+id/tv_set_days" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#999999" android:textSize="13sp" android:paddingStart="28dp" android:layout_marginBottom="3dp" android:fontFamily="sans-serif" />
                    <TextView android:id="@+id/tv_set_distance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#999999" android:textSize="13sp" android:paddingStart="28dp" android:layout_marginBottom="3dp" android:fontFamily="sans-serif" />
                    <TextView android:id="@+id/tv_set_pace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#999999" android:textSize="13sp" android:paddingStart="28dp" android:fontFamily="sans-serif" />
                </LinearLayout>
            </LinearLayout>

            <!-- 과거 목표 목록 (테두리 스타일) -->
            <LinearLayout
                android:id="@+id/layout_history_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_bordered"
                android:layout_marginTop="2dp">

                <LinearLayout
                    android:id="@+id/btn_toggle_history"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/iv_history_icon" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_coaching_history" app:tint="#CCFF00" android:layout_marginEnd="10dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="과거 목표 목록" android:textColor="#FFFFFF" android:textSize="14sp" android:fontFamily="sans-serif-medium" />
                    <ImageView android:id="@+id/iv_history_arrow" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_arrow_down" app:tint="#CCFF00" />
                </LinearLayout>

                <View
                    android:id="@+id/view_history_header_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#CCFF00"
                    android:layout_marginHorizontal="16dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:paddingHorizontal="8dp"
                    android:paddingBottom="8dp"
                    android:nestedScrollingEnabled="false" />
                <TextView android:id="@+id/tv_history_empty" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="히스토리가 없습니다" android:textColor="#444444" android:textSize="13sp" android:gravity="center" android:paddingVertical="16dp" android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>