<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- 지도 -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 지도 오버레이 -->
    <View
        android:id="@+id/map_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/map_overlay_gradient"
        android:clickable="false"
        android:focusable="false" />

    <!-- ════════ 상단 코칭 목표 표시 (코칭 모드일 때만) ════════ -->
    <LinearLayout
        android:id="@+id/layout_coaching_goals"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="90dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <!-- 목표 거리 원형 -->
        <FrameLayout
            android:id="@+id/frame_goal_distance"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginEnd="16dp">

            <View
                android:id="@+id/circle_goal_distance"
                android:layout_width="100dp"
                android:layout_height="100dp" />

            <TextView
                android:id="@+id/tv_goal_distance_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="0/5km"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- 목표 시간 원형 (페이스가 있을 때만 표시) -->
        <FrameLayout
            android:id="@+id/frame_goal_time"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:visibility="gone">

            <View
                android:id="@+id/circle_goal_time"
                android:layout_width="100dp"
                android:layout_height="100dp" />

            <TextView
                android:id="@+id/tv_goal_time_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="30:00"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>
    </LinearLayout>

    <!-- 내 위치 버튼 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btn_my_location"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="25dp"
        app:cardElevation="8dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_my_location"
            app:tint="#FFFFFF" />
    </androidx.cardview.widget.CardView>

    <!-- ════════ 하단 버튼 영역 — 슬라이드 ════════ -->
    <FrameLayout
        android:id="@+id/layout_start_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingBottom="120dp">

        <!-- 코칭 러닝 뾰족 탭 (우측, 기본 상태) -->
        <TextView
            android:id="@+id/tab_coaching_peek"
            android:layout_width="40dp"
            android:layout_height="70dp"
            android:layout_gravity="end|center_vertical"
            android:gravity="center"
            android:text="◀"
            android:textColor="#FF9500"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:visibility="gone" />

        <!-- 자유 러닝 뾰족 탭 (좌측, 코칭 모드일 때) -->
        <TextView
            android:id="@+id/tab_free_peek"
            android:layout_width="40dp"
            android:layout_height="70dp"
            android:layout_gravity="start|center_vertical"
            android:gravity="center"
            android:text="▶"
            android:textColor="#CCFF00"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:visibility="gone" />

        <!-- 자유 러닝 버튼 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_start"
            android:layout_width="200dp"
            android:layout_height="70dp"
            android:layout_gravity="center"
            android:visibility="visible"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#CCFF00"
            app:cardCornerRadius="35dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_start_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="측정 시작"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_start_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="자유 러닝"
                    android:textColor="#000000"
                    android:textSize="13sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 코칭 러닝 버튼 (슬라이드로 나타남) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_start_coaching"
            android:layout_width="200dp"
            android:layout_height="70dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#FF9500"
            app:cardCornerRadius="35dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="측정 시작"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="오늘의 목표"
                    android:textColor="#000000"
                    android:textSize="13sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <!-- ════════ 측정 중 버튼 ════════ -->
    <LinearLayout
        android:id="@+id/layout_running_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="120dp"
        android:paddingHorizontal="24dp"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_pause"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#333333"
            app:cardCornerRadius="35dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tv_pause_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="||"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_stop"
            android:layout_width="200dp"
            android:layout_height="70dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#FF4444"
            app:cardCornerRadius="35dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_elapsed_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00 : 00"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 m"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- ════════ 측정 결과 오버레이 ════════ -->
    <LinearLayout
        android:id="@+id/layout_result"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="측정 완료"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#CCFF00"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="달린 거리"
            android:textSize="14sp"
            android:textColor="#AAAAAA" />
        <TextView
            android:id="@+id/tv_result_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00 km"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="달린 시간"
            android:textSize="14sp"
            android:textColor="#AAAAAA" />
        <TextView
            android:id="@+id/tv_result_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="평균 페이스"
            android:textSize="14sp"
            android:textColor="#AAAAAA" />
        <TextView
            android:id="@+id/tv_result_pace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--/km"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#CCFF00"
            android:layout_marginBottom="40dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_result_confirm"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#CCFF00"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="확인"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</FrameLayout>