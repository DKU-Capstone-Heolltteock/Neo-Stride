<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- 지도 -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 지도 오버레이 -->
    <View
        android:id="@+id/map_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/map_overlay_gradient"
        android:clickable="false"
        android:focusable="false" />

    <!-- 내 위치 버튼 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btn_my_location"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="25dp"
        app:cardElevation="8dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_my_location"
            app:tint="#FFFFFF"
            android:contentDescription="내 위치로 이동" />
    </androidx.cardview.widget.CardView>

    <!-- ════════ 하단 버튼 영역 ════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="120dp"
        android:paddingHorizontal="24dp">

        <!-- 일시정지 버튼 (측정 중에만 VISIBLE) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_pause"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginEnd="12dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#333333"
            app:cardCornerRadius="35dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tv_pause_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="||"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

        </androidx.cardview.widget.CardView>

        <!-- 측정 시작 버튼 (대기 상태) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_start"
            android:layout_width="200dp"
            android:layout_height="70dp"
            android:visibility="visible"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#CCFF00"
            app:cardCornerRadius="35dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="측정 시작"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="자유 러닝"
                    android:textColor="#000000"
                    android:textSize="13sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 측정 중 버튼 (시간/거리 표시, 누르면 종료) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_stop"
            android:layout_width="200dp"
            android:layout_height="70dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#FF4444"
            app:cardCornerRadius="35dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_elapsed_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00 : 00"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 m"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- ════════ 측정 결과 오버레이 ════════ -->
    <LinearLayout
        android:id="@+id/layout_result"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="측정 완료"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#CCFF00"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="달린 거리"
            android:textSize="14sp"
            android:textColor="#AAAAAA" />
        <TextView
            android:id="@+id/tv_result_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00 km"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="달린 시간"
            android:textSize="14sp"
            android:textColor="#AAAAAA" />
        <TextView
            android:id="@+id/tv_result_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="평균 페이스"
            android:textSize="14sp"
            android:textColor="#AAAAAA" />
        <TextView
            android:id="@+id/tv_result_pace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--/km"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#CCFF00"
            android:layout_marginBottom="40dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_result_confirm"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#CCFF00"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="확인"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</FrameLayout>