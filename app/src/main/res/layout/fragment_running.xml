<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- 1. 지도 -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cameraTargetLat="35.9"
        app:cameraTargetLng="127.7"
        app:cameraZoom="7" />
    <View
        android:id="@+id/map_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/map_overlay_gradient"
        android:clickable="false" />

    <!-- 2. 내 위치 버튼 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btn_my_location"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="25dp"
        app:cardElevation="8dp">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_my_location"
            app:tint="#FFFFFF" />
    </androidx.cardview.widget.CardView>

    <!-- 3. 상단 코칭 목표 UI (게이지) -->
    <LinearLayout
        android:id="@+id/layout_coaching_goals"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="90dp"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginEnd="16dp">
            <ProgressBar
                android:id="@+id/progress_goal_distance"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:max="10000"
                android:progressDrawable="@drawable/circular_progress_bar" />
            <TextView
                android:id="@+id/tv_goal_distance_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="110dp"
            android:layout_height="110dp">
            <ProgressBar
                android:id="@+id/progress_goal_time"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:max="10000"
                android:progressDrawable="@drawable/circular_progress_bar" />
            <TextView
                android:id="@+id/tv_goal_time_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>
    </LinearLayout>

    <!-- 4. 하단 슬라이더 영역 (모드 선택) -->
    <FrameLayout
        android:id="@+id/layout_start_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingBottom="120dp"
        android:clipChildren="false"
        android:clipToPadding="false">
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPagerRunningMode"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="55dp"
            android:paddingEnd="55dp" />
    </FrameLayout>

    <!-- 5. 측정 중 컨트롤 (정지/일시정지) -->
    <LinearLayout
        android:id="@+id/layout_running_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:paddingBottom="120dp"
        android:visibility="gone">
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_pause"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_marginEnd="12dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardElevation="0dp"
            app:cardMaxElevation="0dp">

            <ImageView
                android:id="@+id/iv_pause_play"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:padding="0dp"
                android:src="@drawable/ic_pause"
                app:tint="#CCFF00" />
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_stop"
            android:layout_width="200dp"
            android:layout_height="70dp"
            app:cardBackgroundColor="#FF4444"
            app:cardCornerRadius="35dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_elapsed_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- 5-1. [신규 추가] 코칭 목표 달성 세리머니 버튼 -->
    <!-- 자바 에러(btn_goal_completed)를 해결하는 핵심 부분입니다. -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btn_goal_completed"
        android:layout_width="175dp"
        android:layout_height="70dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="125dp"
        app:cardBackgroundColor="#CCFF00"
        app:cardCornerRadius="35dp"
        app:cardElevation="8dp"
        app:cardPreventCornerOverlap="false"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="목표 완료"
                android:textColor="#000000"
                android:textSize="17sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="코칭 탭에서 확인"
                android:textColor="#000000"
                android:textSize="12sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 5-2. 카운트다운 / GPS 확보 대기 오버레이 -->
    <FrameLayout
        android:id="@+id/layout_countdown_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <!-- 가운데 큰 숫자 (또는 GO! / GPS 찾는 중...) -->
        <TextView
            android:id="@+id/tv_countdown_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="3"
            android:textColor="#CCFF00"
            android:textSize="120sp"
            android:textStyle="bold" />

        <!-- 보조 상태 텍스트 (준비... / GPS 찾는 중...) -->
        <TextView
            android:id="@+id/tv_countdown_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="140dp"
            android:text="준비..."
            android:textColor="#BBBBBB"
            android:textSize="16sp" />

        <!-- 우상단 X 취소 버튼 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_countdown_cancel"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="20dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="22dp"
            app:cardElevation="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <!-- 6. 중단 경고 팝업 -->
    <LinearLayout
        android:id="@+id/layout_stop_warning"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_popup_red_border"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tv_warning_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="코칭 중단 경고"
                android:textColor="#FF4444"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_warning_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="목표 거리를 달성하지 못했습니다.\n지금 중단하면 오늘의 코칭 기록이\n저장되지 않습니다."
                android:textColor="#BBBBBB"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333" android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end|center_vertical">

                <TextView
                    android:id="@+id/btn_warning_resume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="취소"
                    android:textColor="#888888"
                    android:textSize="16sp"
                    android:padding="12dp"
                    android:layout_marginEnd="12dp" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_warning_stop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FF4444"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="24dp" android:paddingEnd="24dp"
                        android:paddingTop="10dp" android:paddingBottom="10dp"
                        android:text="중단"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 7. 측정 완료 화면 -->
    <LinearLayout
        android:id="@+id/layout_result"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:padding="32dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="측정 완료"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#CCFF00"
            android:layout_marginBottom="32dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="달린 거리"
            android:textSize="14sp"
            android:textColor="#AAAAAA" />
        <TextView
            android:id="@+id/tv_result_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="달린 시간"
            android:textSize="14sp"
            android:textColor="#AAAAAA" />
        <TextView
            android:id="@+id/tv_result_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="평균 페이스"
            android:textSize="14sp"
            android:textColor="#AAAAAA" />
        <TextView
            android:id="@+id/tv_result_pace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#CCFF00"
            android:layout_marginBottom="40dp" />
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_result_confirm"
            android:layout_width="200dp"
            android:layout_height="56dp"
            app:cardBackgroundColor="#CCFF00"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="확인"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</FrameLayout>