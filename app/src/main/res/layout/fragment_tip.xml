<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 상단 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="255dp"
            android:background="#222222"
            android:orientation="vertical"
            android:paddingStart="26dp"
            android:paddingTop="48dp"
            android:paddingEnd="26dp"
            android:paddingBottom="18dp">

            <!-- 알림 + 마이페이지 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_tip_notification"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_notification"
                    app:tint="#FFD600" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/iv_tip_mypage"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_mypage" />
            </LinearLayout>

            <!-- 제목 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="러닝 팁"
                android:textColor="#CCFF00"
                android:textSize="34sp"
                android:textStyle="bold" />

            <!-- 구분선 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:layout_marginTop="2dp"
                android:background="#CCFF00" />

            <!-- 카테고리 버튼 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_tip_all"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tip_selector"
                    android:gravity="center"
                    android:text="전체"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_tip_training"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tip_selector"
                    android:gravity="center"
                    android:text="훈련"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_tip_course"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tip_selector"
                    android:gravity="center"
                    android:text="코스"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_tip_gear"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tip_selector"
                    android:gravity="center"
                    android:text="장비"
                    android:textColor="#000000"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- 안내 배너 -->
            <TextView
                android:id="@+id/tv_tip_badge_notice"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="10dp"
                android:background="#111111"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:text="팁 게시글은 뱃지 소지자만 작성할 수 있어요"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 팁 리스트 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_tip_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="14dp"
            android:paddingBottom="130dp" />

    </LinearLayout>

    <!-- 팁 작성 버튼 -->
    <ImageView
        android:id="@+id/btn_write_tip"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="110dp"
        android:background="@drawable/bg_write_feed_button"
        android:padding="17dp"
        android:src="@drawable/ic_write_feed"
        app:tint="#CCFF00" />

</FrameLayout>