<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 상단 영역 -->

        <!-- 바깥 배경 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#222222"
            android:orientation="vertical"
            android:paddingStart="26dp"
            android:paddingTop="48dp"
            android:paddingEnd="26dp"
            android:paddingBottom="14dp">

            <!-- 알림 + 마이페이지 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_tip_notification"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_notification"
                    app:tint="#FFD600" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/iv_tip_mypage"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_mypage" />
            </LinearLayout>

            <!-- 제목 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="러닝 팁"
                android:textColor="#CCFF00"
                android:textSize="34sp"
                android:textStyle="bold" />

            <!-- 구분선 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:layout_marginTop="2dp"
                android:background="#CCFF00" />

            <!-- 카테고리 버튼 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_tip_all"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tip_selector"
                    android:gravity="center"
                    android:text="전체"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_tip_free"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tip_selector"
                    android:gravity="center"
                    android:text="자유"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_tip_training"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tip_selector"
                    android:gravity="center"
                    android:text="훈련"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_tip_course"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tip_selector"
                    android:gravity="center"
                    android:text="코스"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_tip_gear"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tip_selector"
                    android:gravity="center"
                    android:text="장비"
                    android:textColor="#000000"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:padding="4dp"
            android:background="@drawable/bg_badge_outer"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 안쪽 배경 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_badge_inner"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="10dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_badge" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="팁은 배지 소지자만 작성할 수 있어요"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/btn_go_my"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_badge_btn"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:text="마이페이지 배지 확인"
                    android:textColor="#000000"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

        <!-- 팁 리스트 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_tip_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="14dp"
            android:paddingBottom="130dp" />

    </LinearLayout>

    <!-- 팁 작성 버튼 -->
    <ImageView
        android:id="@+id/btn_write_tip"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/bg_write_feed_button"
        android:padding="17dp"
        android:src="@drawable/ic_write_feed"
        app:tint="#CCFF00" />

</FrameLayout>