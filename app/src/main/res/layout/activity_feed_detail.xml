<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_feed_detail_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0B0B">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="false"
        android:paddingBottom="130dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="36dp"
            android:paddingEnd="16dp"
            android:paddingBottom="0dp">

            <!-- 상단 뒤로가기 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp">

                <ImageView
                    android:id="@+id/btn_feed_detail_back"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="start|center_vertical"
                    android:padding="7dp"
                    android:src="@drawable/ic_arrow_left"
                    app:tint="#B8FF06" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="피드 상세"
                    android:textColor="#B8FF06"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- 달린 루트 보기 -->
            <LinearLayout
                android:id="@+id/layout_route_header"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_feed_detail_toggle"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <ImageView
                    android:id="@+id/iv_route_gradient_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_chart" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="달린 루트 보기"
                    android:textColor="#B8FF06"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_route_arrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="#B8FF06" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_route_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_feed_detail_section"
                android:orientation="vertical"
                android:padding="10dp">

                <ImageView
                    android:id="@+id/iv_detail_route_map"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:background="#222222"
                    android:scaleType="fitCenter" />
            </LinearLayout>

            <!-- 기록 정보 보기 -->
            <LinearLayout
                android:id="@+id/layout_record_header"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_feed_detail_toggle"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <ImageView
                    android:id="@+id/iv_record_gradient_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_record_info"
                    app:tint="#B8FF06" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="기록 정보 보기"
                    android:textColor="#B8FF06"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_record_arrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="#B8FF06" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_record_content"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_feed_detail_section"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <!-- 거리 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_detail_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3.25 km"
                        android:textColor="#B8FF06"
                        android:textSize="23sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="DISTANCE"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="48dp"
                    android:background="#333333" />

                <!-- 시간 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_detail_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18:42"
                        android:textColor="#B8FF06"
                        android:textSize="23sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="TIME"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="48dp"
                    android:background="#333333" />

                <!-- 페이스 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_detail_pace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5:45/km"
                        android:textColor="#B8FF06"
                        android:textSize="23sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="PACE"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- 피드 본문 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_feed_detail_card"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- 작성자 영역 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/iv_detail_profile"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:adjustViewBounds="false"
                        android:background="@null"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_profile" />

                    <TextView
                        android:id="@+id/tv_detail_username"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="9dp"
                        android:ellipsize="end"
                        android:maxWidth="145dp"
                        android:singleLine="true"
                        android:text="JinzaYoungjae3218"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- 작성자 뱃지: 닉네임 바로 오른쪽 -->
                    <ImageView
                        android:id="@+id/iv_detail_badge"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_badge"
                        android:visibility="gone" />

                    <!-- 닉네임/뱃지를 왼쪽에 고정시키고 시간/태그를 오른쪽으로 미는 Spacer -->
                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_detail_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:text="2026.05.16"
                        android:textColor="#A0A0A0"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <!-- 피드 태그 뱃지 : 아이콘 + 숫자 -->
                    <TextView
                        android:id="@+id/tv_detail_tag_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_feed_tag_badge"
                        android:drawableStart="@drawable/ic_tag_people"
                        android:drawablePadding="5dp"
                        android:drawableTint="#B8FF06"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:paddingStart="11dp"
                        android:paddingEnd="11dp"
                        android:singleLine="true"
                        android:text="2"
                        android:textColor="#B8FF06"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_detail_more"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:gravity="center"
                        android:text="⋯"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 제목 -->
                <TextView
                    android:id="@+id/tv_detail_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="오운완"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- 내용 -->
                <TextView
                    android:id="@+id/tv_detail_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="3dp"
                    android:text="캡스톤 멤버들과 달리기"
                    android:textColor="#EAEAEA"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- 피드 이미지 -->
                <ImageView
                    android:id="@+id/iv_detail_feed_photo"
                    android:layout_width="match_parent"
                    android:layout_height="210dp"
                    android:layout_marginTop="12dp"
                    android:background="#1F1F1F"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <!-- 구분선 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:background="#4A4A4A" />

                <!-- 좋아요 / 댓글 / 북마크 액션 영역 -->
                <LinearLayout
                    android:id="@+id/layout_detail_action_area"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <!-- 좋아요 -->
                    <LinearLayout
                        android:id="@+id/layout_detail_like_box"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_feed_detail_action_item"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <ImageView
                            android:id="@+id/iv_detail_like"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_like"
                            app:tint="#FFFFFF" />

                        <TextView
                            android:id="@+id/tv_detail_like_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:ellipsize="end"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:text="좋아요 3"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 댓글 -->
                    <LinearLayout
                        android:id="@+id/layout_detail_comment_box"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_feed_detail_action_item"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <ImageView
                            android:id="@+id/iv_detail_comment"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_comment"
                            app:tint="#FFFFFF" />

                        <TextView
                            android:id="@+id/tv_detail_comment_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:ellipsize="end"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:text="댓글 2"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 북마크 -->
                    <LinearLayout
                        android:id="@+id/layout_detail_bookmark_box"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_feed_detail_action_item"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <ImageView
                            android:id="@+id/iv_detail_bookmark"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_bookmark"
                            app:tint="#FFFFFF" />

                        <TextView
                            android:id="@+id/tv_detail_bookmark"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:ellipsize="end"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:text="북마크"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 구분선 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="6dp"
                    android:background="#4A4A4A" />

                <!-- 댓글 제목 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="댓글"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- 댓글이 없을 때 표시할 문구 -->
                <TextView
                    android:id="@+id/tv_empty_comment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp"
                    android:text="아직 댓글이 없습니다."
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- Java에서 댓글 View를 동적으로 추가할 영역 -->
                <LinearLayout
                    android:id="@+id/layout_comment_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />

                <!--
                    하단 댓글 입력창이 fixed로 떠 있기 때문에,
                    카드 배경이 입력창 뒤까지 이어지도록 여백을 카드 내부에 둠.
                    이렇게 해야 입력창 위/뒤에 검은 빈 배경이 생기지 않음.
                -->
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 하단 댓글 입력창 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/bg_feed_detail_comment_input"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="12dp">

        <EditText
            android:id="@+id/et_detail_comment"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="댓글을 입력하세요."
            android:inputType="text"
            android:singleLine="true"
            android:textColor="#FFFFFF"
            android:textColorHint="#BBBBBB"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/btn_send_comment"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_write_feed"
            app:tint="#B8FF06" />
    </LinearLayout>

</FrameLayout>