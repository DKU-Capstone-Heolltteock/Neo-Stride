<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111"
    android:paddingStart="24dp"
    android:paddingEnd="24dp">

    <TextView
        android:id="@+id/tvSuccessIcon"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:gravity="center"
        android:text="✓"
        android:textColor="#B8FF06"
        android:textSize="34sp"
        android:background="@drawable/bg_success_circle"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="170dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSuccessTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Successful"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvSuccessIcon"
        android:layout_marginTop="230dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSuccessDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Congratulation! Your password has\nbeen changed. Click continue to login"
        android:textColor="#9E9E9E"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvSuccessTitle"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnContinueToLogin"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:text="Continue to Login"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textColor="#000000"
        android:backgroundTint="#B8FF06"
        app:cornerRadius="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvSuccessDesc"
        android:layout_marginTop="30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>