<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_feed_upload_dialog"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btn_back_picker"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_left"
            android:tint="#CCFF00" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="기록 선택"
            android:textColor="#CCFF00"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="46dp"
            android:layout_height="46dp" />

    </LinearLayout>

    <!-- 월 헤더 (클릭 시 년/월 선택 팝업) -->
    <TextView
        android:id="@+id/tv_picker_month_year"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="2026년 5월"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginTop="4dp" />

    <!-- 요일 헤더 (일~토) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="일" android:textColor="#FF4444" android:textSize="11sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="월" android:textColor="#888888" android:textSize="11sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="화" android:textColor="#888888" android:textSize="11sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="수" android:textColor="#888888" android:textSize="11sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="목" android:textColor="#888888" android:textSize="11sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="금" android:textColor="#888888" android:textSize="11sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="토" android:textColor="#4488FF" android:textSize="11sp" android:textStyle="bold" />

    </LinearLayout>

    <!-- 달력 ViewPager2 (스와이프로 월 이동 — 기록 영역 포함) -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vp_picker_calendar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="2dp" />

</LinearLayout>
