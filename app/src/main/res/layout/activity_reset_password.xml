<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111"
    android:padding="32dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Reset password"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="120dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Please enter your email and ID to reset the password"
        android:textColor="#9E9E9E"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvIdLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="your ID"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvDesc"
        android:layout_marginTop="32dp"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etResetId"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:hint="Enter your ID"
        android:textColor="#FFFFFF"
        android:textColorHint="#A0A0A0"
        android:textSize="16sp"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:background="@drawable/bg_input_round"
        android:singleLine="true"
        app:layout_constraintTop_toBottomOf="@id/tvIdLabel"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvEmailLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="your email"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/etResetId"
        android:layout_marginTop="28dp"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etResetEmail"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:hint="Enter your email"
        android:textColor="#FFFFFF"
        android:textColorHint="#A0A0A0"
        android:textSize="16sp"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:background="@drawable/bg_input_round"
        android:singleLine="true"
        android:inputType="textEmailAddress"
        app:layout_constraintTop_toBottomOf="@id/tvEmailLabel"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnResetContinue"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="Continue"
        android:textColor="#000000"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:backgroundTint="#B8FF06"
        app:cornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@id/etResetEmail"
        android:layout_marginTop="42dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvFindId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot your ID? Click Here"
        android:textColor="#9E9E9E"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnResetContinue"
        android:layout_marginTop="36dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>