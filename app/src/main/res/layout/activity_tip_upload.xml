<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <LinearLayout
        android:layout_width="340dp"
        android:layout_height="680dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_tip_upload_box"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:contentDescription="back"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_left"
                app:tint="#CCFF00" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Tip Upload"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_done"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:gravity="center"
                android:text="완료"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_category_free"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tip_selector"
                android:gravity="center"
                android:text="자유"
                android:textColor="#000000"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_category_training"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tip_selector"
                android:gravity="center"
                android:text="훈련"
                android:textColor="#000000"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_category_course"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tip_selector"
                android:gravity="center"
                android:text="코스"
                android:textColor="#000000"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_category_gear"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tip_selector"
                android:gravity="center"
                android:text="장비"
                android:textColor="#000000"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="내 게시물"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_gps"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="2dp"
                android:padding="0dp"
                android:src="@drawable/ic_location"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/btn_add_photo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="0dp"
                android:src="@drawable/ic_image" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_selected_photos"
            android:layout_width="match_parent"
            android:layout_height="86dp"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tip_input_box"
            android:orientation="vertical"
            android:padding="14dp">

            <EditText
                android:id="@+id/et_tip_title"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:hint="제목을 입력해주세요."
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#BDBDBD"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCFF00" />

            <EditText
                android:id="@+id/et_tip_content"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:gravity="top"
                android:hint="여기에 내용을 입력하면 해당 내용이 팁 게시판에서 보여지는 텍스트 영역입니다."
                android:textColor="#FFFFFF"
                android:textColorHint="#BDBDBD"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>