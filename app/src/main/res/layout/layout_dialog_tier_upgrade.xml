<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="270dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_bordered"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp">

    <!-- 배지 아이콘 -->
    <ImageView
        android:id="@+id/iv_tier_icon"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="14dp"
        android:src="@drawable/ic_badge" />

    <!-- 타이틀 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="10dp"
        android:text="배지 등급 상승!"
        android:textColor="#CCFF00"
        android:textSize="19sp"
        android:textStyle="bold" />

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="20dp"
        android:background="#2A2A2A" />

    <!-- 이전 등급 → 새 등급 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- 이전 등급 -->
        <TextView
            android:id="@+id/tv_old_tier"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- 화살표 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:text="→"
            android:textColor="#555555"
            android:textSize="18sp" />

        <!-- 새 등급 -->
        <TextView
            android:id="@+id/tv_new_tier"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:gravity="center"
            android:paddingHorizontal="18dp"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 축하 메시지 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="22dp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:text="새로운 등급을 달성했어요!\n계속 달려서 더 높이 올라가세요."
        android:textColor="#AAAAAA"
        android:textSize="13sp" />

    <!-- 확인 버튼 -->
    <TextView
        android:id="@+id/btn_tier_confirm"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_badge_btn"
        android:gravity="center"
        android:paddingHorizontal="36dp"
        android:text="확인"
        android:textColor="#111111"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>
