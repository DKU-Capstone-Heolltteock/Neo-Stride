<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_tip_upload_box"
    android:padding="20dp">

    <!-- 상단 헤더 — 피드/팁 업로드와 동일한 정렬 구조 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:contentDescription="back"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_left"
            android:tint="#CCFF00" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Privacy"
            android:textColor="#CCFF00"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_done"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:gravity="center"
            android:text="완료"
            android:textColor="#CCFF00"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 나만 보기 -->
    <RadioGroup
        android:id="@+id/radio_group_privacy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp">

        <RadioButton
            android:id="@+id/radio_private"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="나만 보기"
            android:textColor="#FFFFFF"
            android:buttonTint="#CCFF00"
            android:textSize="18sp"
            android:padding="10dp" />

        <RadioButton
            android:id="@+id/radio_friend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="친구에게 공개"
            android:textColor="#FFFFFF"
            android:buttonTint="#CCFF00"
            android:textSize="18sp"
            android:padding="10dp" />

        <RadioButton
            android:id="@+id/radio_badge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="배지홀더에게 공개"
            android:textColor="#FFFFFF"
            android:buttonTint="#CCFF00"
            android:textSize="18sp"
            android:padding="10dp" />

        <RadioButton
            android:id="@+id/radio_public"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="모두에게 공개"
            android:textColor="#FFFFFF"
            android:buttonTint="#CCFF00"
            android:textSize="18sp"
            android:padding="10dp" />

    </RadioGroup>

</LinearLayout>