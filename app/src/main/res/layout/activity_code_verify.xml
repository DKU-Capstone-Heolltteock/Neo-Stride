<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <TextView
        android:id="@+id/tv_check_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Check your email"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="90dp"
        android:layout_marginStart="28dp" />

    <TextView
        android:id="@+id/tv_check_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="We sent a reset link to contact@dscode.com\nenter 5 digit code that mentioned in the email"
        android:textColor="#888888"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tv_check_title"
        app:layout_constraintStart_toStartOf="@id/tv_check_title"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="28dp" />

    <LinearLayout
        android:id="@+id/layout_code_boxes"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="5"
        app:layout_constraintTop_toBottomOf="@id/tv_check_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginTop="60dp">

        <EditText
            android:id="@+id/et_code_1"
            style="@style/CodeBoxStyle" />

        <EditText
            android:id="@+id/et_code_2"
            style="@style/CodeBoxStyle" />

        <EditText
            android:id="@+id/et_code_3"
            style="@style/CodeBoxStyle" />

        <EditText
            android:id="@+id/et_code_4"
            style="@style/CodeBoxStyle" />

        <EditText
            android:id="@+id/et_code_5"
            style="@style/CodeBoxStyle" />

    </LinearLayout>

    <Button
        android:id="@+id/btn_verify_code"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Verify Code"
        android:textColor="#000000"
        android:textStyle="bold"
        android:backgroundTint="#B8FF06"
        app:layout_constraintTop_toBottomOf="@id/layout_code_boxes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="28dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp" />

    <TextView
        android:id="@+id/tv_resend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Haven’t got the email yet? Resend Code"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/btn_verify_code"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>