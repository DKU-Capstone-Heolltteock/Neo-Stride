<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginTop="12dp"
    android:background="@drawable/bg_feed_card_bordered"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- 상단 프로필 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/iv_tip_profile"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:adjustViewBounds="false"
            android:background="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_profile" />

        <TextView
            android:id="@+id/tv_tip_nickname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:maxWidth="120dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="zinza" />

        <ImageView
            android:id="@+id/iv_tip_badge"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_badge" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_tip_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:textColor="#9A9A9A"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="2026.05.16" />

        <ImageView
            android:id="@+id/iv_tip_bookmark"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/ic_bookmark"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tv_tip_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:text="···"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>


    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCFF00" />

    <!-- 본문 영역 -->
    <LinearLayout
        android:id="@+id/layout_tip_body"
        android:layout_width="match_parent"
        android:layout_height="108dp"
        android:layout_marginTop="10dp"
        android:gravity="top"
        android:orientation="horizontal">

        <androidx.cardview.widget.CardView
            android:id="@+id/card_tip_photo"
            android:layout_width="108dp"
            android:layout_height="108dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/iv_tip_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:src="@drawable/sample_photo" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/layout_tip_text_area"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <!-- 제목 + GPS + 카테고리 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_tip_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#B8FF06"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="러닝 팁 제목" />

                <ImageView
                    android:id="@+id/iv_tip_gps"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/ic_location"
                    android:visibility="gone"
                    app:tint="#B8FF06" />

                <TextView
                    android:id="@+id/tv_tip_category"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:background="@drawable/bg_feed_tag"
                    android:gravity="center"
                    android:minWidth="42dp"
                    android:paddingHorizontal="9dp"
                    android:text="자유"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_tip_content"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="3"
                android:textColor="#CFCFCF"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="러닝 팁 내용이 여기에 표시됩니다." />

            <!-- 좋아요 / 댓글 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_tip_like"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_like"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/tv_tip_like_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_tip_comment"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="14dp"
                    android:src="@drawable/ic_comment"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/tv_tip_comment_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>