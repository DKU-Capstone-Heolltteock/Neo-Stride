<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 상단 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_community_header_round"
            android:orientation="vertical"
            android:paddingStart="26dp"
            android:paddingTop="22dp"
            android:paddingEnd="26dp"
            android:paddingBottom="18dp">

            <!-- 제목 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="피드"
                android:textColor="#CCFF00"
                android:textSize="34sp"
                android:textStyle="bold" />

            <!-- 구분선 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:layout_marginTop="6dp"
                android:background="#CCFF00" />
        </LinearLayout>

        <!-- 피드 리스트 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_feed_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="14dp"
            android:paddingBottom="130dp" />

    </LinearLayout>

    <!-- 글쓰기 버튼 -->
    <ImageView
        android:id="@+id/btn_write_feed"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="110dp"
        android:background="@drawable/bg_write_feed_button"
        android:padding="17dp"
        android:src="@drawable/ic_write_feed"
        app:tint="#CCFF00" />

</FrameLayout>