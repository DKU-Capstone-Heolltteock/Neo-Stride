<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 상단 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#222222"
            android:orientation="vertical"
            android:paddingStart="26dp"
            android:paddingTop="48dp"
            android:paddingEnd="26dp"
            android:paddingBottom="18dp">

            <!-- 알림 + 마이페이지 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_feed_notification"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_notification"
                    app:tint="#FFD600"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/iv_feed_mypage"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_mypage" />
            </LinearLayout>

            <!-- 제목 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="피드"
                android:textColor="#CCFF00"
                android:textSize="34sp"
                android:textStyle="bold" />

            <!-- 구분선 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:layout_marginTop="2dp"
                android:background="#CCFF00" />
        </LinearLayout>

        <!-- 피드 리스트 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_feed_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="14dp"
            android:paddingBottom="130dp" />

    </LinearLayout>

    <!-- 글쓰기 버튼 -->
    <ImageView
        android:id="@+id/btn_write_feed"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="110dp"
        android:background="@drawable/bg_write_feed_button"
        android:padding="17dp"
        android:src="@drawable/ic_write_feed"
        app:tint="#CCFF00" />

</FrameLayout>