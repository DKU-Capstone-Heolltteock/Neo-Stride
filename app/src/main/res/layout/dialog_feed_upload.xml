<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_feed_upload_dialog"
    android:fillViewport="true"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 상단 헤더 (팁 업로드와 동일 구조) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_back_upload"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:contentDescription="back"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_left"
                app:tint="#CCFF00" />

            <TextView
                android:id="@+id/tv_upload_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Feed Upload"
                android:textColor="#CCFF00"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_complete_upload"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:gravity="center"
                android:text="완료"
                android:textColor="#CCFF00"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 사람 태그 / 공개 범위 / 지도 표시 -->
        <LinearLayout
            android:id="@+id/layout_tag_people"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_community"
                android:tint="#CCFF00" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="사람 태그"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_tag_count"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_badge_btn"
                android:gravity="center"
                android:text="0"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_arrow_right"
                android:tint="#CCFF00" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_privacy"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_public"
                android:tint="#CCFF00" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="공개 범위"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_privacy_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="친구"
                android:textColor="#BDBDBD"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_arrow_right"
                android:tint="#CCFF00" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_map_visible"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_event"
                android:tint="#CCFF00" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="지도 표시"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_map_visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:thumbTint="@color/switch_thumb_tint"
                app:trackTint="@color/switch_track_tint" />
        </LinearLayout>

        <!-- 게시물 + 사진 추가 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="내 게시물"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_add_photo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="0dp"
                android:src="@drawable/ic_image"
                android:tint="#CCFF00" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_selected_photos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:visibility="gone" />

        <!-- 제목 + 내용 입력 박스 (남은 공간 전체를 채움) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_tip_input_box"
            android:orientation="vertical"
            android:padding="14dp">

            <EditText
                android:id="@+id/et_feed_title"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:hint="제목을 입력해주세요."
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#BDBDBD"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCFF00" />

            <EditText
                android:id="@+id/et_feed_content"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="10dp"
                android:background="@android:color/transparent"
                android:gravity="top"
                android:hint="여기에 내용을 입력하면 해당 내용이 피드에서 보여지는 텍스트 영역입니다."
                android:textColor="#FFFFFF"
                android:textColorHint="#BDBDBD"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
