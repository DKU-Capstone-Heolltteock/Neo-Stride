<?xml version="1.0" encoding="utf-8"?>
<!-- 상세기록 탭의 뜨는 날짜(일 단위) 들에 대한 XML -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackgroundBorderless">

    <View
        android:id="@+id/view_selected_bg"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:background="@drawable/bg_calendar_selected"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/tv_day"
        app:layout_constraintBottom_toBottomOf="@id/tv_day"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="28"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintVertical_bias="0.35"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_distance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="10.4km"
        android:textColor="#CCFF00"
        android:textSize="8sp"
        android:visibility="gone"
        android:layout_marginTop="1dp"
        app:layout_constraintTop_toBottomOf="@id/tv_day"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/view_plan_dot"
        android:layout_width="5dp"
        android:layout_height="5dp"
        android:layout_marginBottom="3dp"
        android:background="@drawable/bg_plan_dot"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>