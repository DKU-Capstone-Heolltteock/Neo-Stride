<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_tip_detail_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <!-- 전체 내용 영역 — Feed 상세와 통일 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="36dp"
        android:paddingEnd="16dp"
        android:paddingBottom="0dp">

        <!-- 상단 제목 영역 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="50dp">

            <ImageView
                android:id="@+id/btn_tip_detail_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="start|center_vertical"
                android:padding="6dp"
                android:src="@drawable/ic_arrow_left"
                android:tint="#B8FF06" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="러닝 팁 상세"
                android:textColor="#B8FF06"
                android:textSize="22sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- 본문 스크롤 영역 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="false"
            android:overScrollMode="never"
            android:paddingBottom="130dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 팁 상세 카드 — Feed 상세와 통일 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_tip_detail_card"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- 작성자 영역 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/iv_tip_detail_profile"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:adjustViewBounds="false"
                            android:background="@null"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_profile" />

                        <TextView
                            android:id="@+id/tv_tip_detail_nickname"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="9dp"
                            android:text="onlyRunning1234"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <!-- 뱃지를 닉네임 오른쪽으로 이동함 (색상은 코드에서 등급별로 setColorFilter) -->
                        <ImageView
                            android:id="@+id/iv_tip_detail_badge"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_badge"
                            android:visibility="gone" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tv_tip_detail_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:text="2026.05.16"
                            android:textColor="#A5A5A5"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_tip_detail_more"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:gravity="center"
                            android:text="•••"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 코스 GPS 상단 배너 -->
                    <LinearLayout
                        android:id="@+id/layout_tip_detail_gps_banner"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_tip_detail_gps_banner"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/iv_tip_detail_gps"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:padding="4dp"
                            android:src="@drawable/ic_location"
                            android:tint="#B8FF06" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:text="GPS 코스 정보가 포함된 러닝 팁입니다"
                            android:textColor="#B8FF06"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/tv_tip_detail_course_toggle"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_arrow_down"
                            android:tint="#CCFF00" />
                    </LinearLayout>

                    <!-- 코스 지도 펼침 영역 -->
                    <LinearLayout
                        android:id="@+id/layout_tip_detail_course_map"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_tip_comment_neon_item"
                        android:orientation="vertical"
                        android:padding="10dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/iv_tip_detail_course_map"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:background="#2E2E2E"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_image" />

                        <!-- 코스 주소 카드 (경로 지도 아래) -->
                        <LinearLayout
                            android:id="@+id/layout_tip_detail_course_address"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_tip_detail_gps_banner"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:visibility="gone">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="10dp"
                                android:src="@drawable/ic_location"
                                android:tint="#B8FF06" />

                            <TextView
                                android:id="@+id/tv_tip_detail_course_address"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:lineSpacingMultiplier="1.3"
                                android:textColor="#EEEEEE"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- 제목 + 카테고리 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_tip_detail_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="단대 근처 러닝 장소 추천해요"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_tip_detail_category"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_tip_detail_category"
                            android:gravity="center"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="코스"
                            android:textColor="#69F8FF"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 본문 -->
                    <TextView
                        android:id="@+id/tv_tip_detail_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:lineSpacingExtra="4dp"
                        android:text="원래 그냥 집 주변길 따라 뛰었는데, 최근에 한번 뛰어보고 괜찮은 것 같아서 추천드립니다."
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- 이미지 영역 -->
                    <ImageView
                        android:id="@+id/iv_tip_detail_image"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="18dp"
                        android:background="#2E2E2E"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <!-- 구분선 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:background="#4A4A4A" />

                    <!-- 좋아요 / 댓글 / 북마크 액션 영역 — Feed 상세와 통일 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <!-- 좋아요 -->
                        <LinearLayout
                            android:id="@+id/layout_tip_detail_like_area"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tip_detail_action_item"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp">

                            <ImageView
                                android:id="@+id/iv_tip_detail_like"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_like"
                                android:tint="#FFFFFF" />

                            <TextView
                                android:id="@+id/tv_tip_detail_like_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:ellipsize="end"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:singleLine="true"
                                android:text="좋아요 8"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- 댓글 -->
                        <LinearLayout
                            android:id="@+id/layout_tip_detail_comment_area"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="6dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tip_detail_action_item"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp">

                            <ImageView
                                android:id="@+id/iv_tip_detail_comment"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_comment"
                                android:tint="#FFFFFF" />

                            <TextView
                                android:id="@+id/tv_tip_detail_comment_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:ellipsize="end"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:singleLine="true"
                                android:text="댓글 2"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- 북마크 -->
                        <LinearLayout
                            android:id="@+id/layout_tip_detail_bookmark_area"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tip_detail_action_item"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp">

                            <ImageView
                                android:id="@+id/iv_tip_detail_bookmark"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_bookmark"
                                android:tint="#FFFFFF" />

                            <TextView
                                android:id="@+id/tv_tip_detail_bookmark"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:ellipsize="end"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:singleLine="true"
                                android:text="북마크"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 구분선 — Feed와 동일 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="6dp"
                        android:background="#4A4A4A" />

                    <!-- 댓글 제목 -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="댓글"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- 댓글이 없을 때 표시할 문구 — 댓글 목록 위에 배치 -->
                    <TextView
                        android:id="@+id/tv_tip_detail_empty_comment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:paddingTop="20dp"
                        android:paddingBottom="20dp"
                        android:text="아직 댓글이 없습니다."
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <!-- 댓글 목록 영역 -->
                    <LinearLayout
                        android:id="@+id/layout_tip_detail_comments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical" />

                    <!--
                        하단 댓글 입력창이 화면 아래 fixed로 떠 있기 때문에,
                        팁 카드 배경이 입력창 뒤까지 이어지도록 카드 내부에 여백을 둠.
                        이렇게 해야 입력창 위/뒤에 검은 빈 배경이 생기지 않음.
                    -->
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- 하단 댓글 입력창 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/bg_tip_comment_input"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="10dp">

        <EditText
            android:id="@+id/et_tip_detail_comment"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="댓글을 입력하세요."
            android:inputType="text"
            android:singleLine="true"
            android:textColor="#FFFFFF"
            android:textColorHint="#A5A5A5"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/btn_tip_detail_send_comment"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="7dp"
            android:src="@drawable/ic_write_feed"
            android:tint="#B8FF06" />
    </LinearLayout>

</FrameLayout>