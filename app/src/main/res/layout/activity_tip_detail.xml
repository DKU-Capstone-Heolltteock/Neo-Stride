<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_tip_detail_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="54dp"
        android:paddingEnd="24dp"
        android:paddingBottom="34dp">

        <!-- 상단 제목 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_tip_detail_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/ic_arrow_left"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="러닝 팁"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 본문 스크롤 영역 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="26dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 팁 상세 카드 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tip_detail_card"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="18dp">

                    <!-- 작성자 영역 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/iv_tip_detail_profile"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:src="@drawable/ic_profile" />

                        <TextView
                            android:id="@+id/tv_tip_detail_nickname"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="9dp"
                            android:text="onlyRunning1234"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_tip_detail_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="· 방금 전"
                            android:textColor="#A5A5A5"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tv_tip_detail_more"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:gravity="center"
                            android:text="•••"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 제목 + 카테고리 + 배지 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_tip_detail_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="단대 근처 러닝 장소 추천해요"
                            android:textColor="#FFFFFF"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_tip_detail_category"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_tip_detail_category"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="코스"
                            android:textColor="#69F8FF"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_tip_detail_badge"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_badge"
                            android:tint="#C8902E" />
                    </LinearLayout>

                    <!-- 본문 -->
                    <TextView
                        android:id="@+id/tv_tip_detail_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="3dp"
                        android:text="원래 그냥 집 주변길 따라 뛰었는데, 최근에 한번 뛰어보고 괜찮은 것 같아서 추천드립니다."
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- 이미지 + GPS 아이콘 영역 -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="190dp"
                        android:layout_marginTop="18dp">

                        <ImageView
                            android:id="@+id/iv_tip_detail_image"
                            android:layout_width="170dp"
                            android:layout_height="150dp"
                            android:layout_gravity="center"
                            android:background="#2E2E2E"
                            android:scaleType="centerCrop" />

                        <ImageView
                            android:id="@+id/iv_tip_detail_gps"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="end|bottom"
                            android:layout_marginEnd="4dp"
                            android:layout_marginBottom="4dp"
                            android:background="@drawable/bg_tip_detail_gps"
                            android:padding="10dp"
                            android:src="@drawable/ic_location"
                            android:tint="#B8FF06" />
                    </FrameLayout>

                    <!-- 구분선 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:background="#7A7A7A" />

                    <!-- 좋아요 / 댓글 / 북마크 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_tip_detail_like_count"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:drawableStart="@drawable/ic_like"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical"
                            android:text="좋아요 3"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_tip_detail_comment_count"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginStart="24dp"
                            android:drawableStart="@drawable/ic_comment"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical"
                            android:text="댓글 2"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <ImageView
                            android:id="@+id/iv_tip_detail_bookmark"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:padding="5dp"
                            android:src="@drawable/ic_bookmark"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginStart="5dp"
                            android:gravity="center_vertical"
                            android:text="북마크"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 구분선 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#7A7A7A" />

                    <!-- 댓글 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="32dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:src="@drawable/ic_profile" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="7dp"
                                android:text="GosuRunner444 · 4분 전"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <Space
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <TextView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:gravity="center"
                                android:text="•••"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="32dp"
                            android:layout_marginTop="2dp"
                            android:text="헐떡헐떡.."
                            android:textColor="#DADADA"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- 댓글 구분선 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:background="#6A6A6A" />

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- 하단 댓글 입력창 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_tip_comment_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="10dp">

            <EditText
                android:id="@+id/et_tip_detail_comment"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="댓글을 입력하세요."
                android:inputType="text"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#A5A5A5"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/btn_tip_detail_send_comment"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:padding="7dp"
                android:src="@drawable/ic_write_feed"
                android:tint="#B8FF06" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>