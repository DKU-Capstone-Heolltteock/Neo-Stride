<?xml version="1.0" encoding="utf-8"?>
<!-- 1. CardView를 제거하고 투명한 LinearLayout으로 변경하여 불필요한 마진을 없앱니다 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- 2. 실제 데이터가 들어가는 영역 (상단과 양옆에만 패딩을 줍니다) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="16dp"
        android:paddingHorizontal="14dp">

        <!-- 상태 점 (Dot) -->
        <View
            android:id="@+id/view_status_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_plan_dot" />

        <!-- 목표 텍스트 정보 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_history_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_history_period"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- 복원 버튼 -->
        <TextView
            android:id="@+id/btn_history_restore"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:text="복원"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <!-- 삭제 버튼 -->
        <TextView
            android:id="@+id/btn_history_delete"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:text="삭제"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 3. 구분선 (여기서 marginTop을 주어 텍스트와의 간격을 조절하고, 아래쪽 패딩은 주지 않습니다) -->
    <View
        android:id="@+id/view_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="12dp"
        android:background="#333333" />

</LinearLayout>