<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <TextView
        android:id="@+id/tv_auth_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Authentication"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="80dp"
        android:layout_marginStart="24dp"/>

    <TextView
        android:id="@+id/tv_auth_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="verify your identity"
        android:textColor="#888888"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tv_auth_title"
        app:layout_constraintStart_toStartOf="@id/tv_auth_title"
        android:layout_marginTop="6dp"/>

    <TextView
        android:id="@+id/tv_email_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="your email"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tv_auth_subtitle"
        app:layout_constraintStart_toStartOf="@id/tv_auth_title"
        android:layout_marginTop="55dp"/>

    <EditText
        android:id="@+id/et_auth_email"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:hint="Enter your email"
        android:textColor="#FFFFFF"
        android:textColorHint="#AAAAAA"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:background="@drawable/bg_email_input"
        android:inputType="textEmailAddress"
        app:layout_constraintTop_toBottomOf="@id/tv_email_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btn_continue"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Continue"
        android:textColor="#000000"
        android:textStyle="bold"
        android:backgroundTint="#B8FF06"
        app:layout_constraintTop_toBottomOf="@id/et_auth_email"
        app:layout_constraintStart_toStartOf="@id/et_auth_email"
        app:layout_constraintEnd_toEndOf="@id/et_auth_email"
        android:layout_marginTop="26dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>