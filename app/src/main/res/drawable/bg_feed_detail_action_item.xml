<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 눌렀을 때 -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#263300" />
            <stroke
                android:width="1.5dp"
                android:color="#B8FF06" />
            <corners android:radius="14dp" />
            <padding
                android:left="8dp"
                android:top="6dp"
                android:right="8dp"
                android:bottom="6dp" />
        </shape>
    </item>

    <!-- 기본 상태 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#141414" />
            <stroke
                android:width="1dp"
                android:color="#55B8FF06" />
            <corners android:radius="14dp" />
            <padding
                android:left="8dp"
                android:top="6dp"
                android:right="8dp"
                android:bottom="6dp" />
        </shape>
    </item>

</selector>