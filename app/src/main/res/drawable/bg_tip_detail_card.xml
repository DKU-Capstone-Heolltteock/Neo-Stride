<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 바깥 네온 윤곽 -->
    <item>
        <shape>
            <solid android:color="#050505" />
            <corners android:radius="28dp" />
            <stroke
                android:width="2dp"
                android:color="#B8FF06" />
        </shape>
    </item>

    <!-- 안쪽 카드 -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">

        <shape>
            <solid android:color="#242424" />
            <corners android:radius="26dp" />
            <stroke
                android:width="1dp"
                android:color="#3A3A3A" />
        </shape>
    </item>

</layer-list>