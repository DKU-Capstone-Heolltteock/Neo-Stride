<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. 가장 바깥쪽의 아주 얇은 테두리 (가이드 라인) -->
    <item>
        <shape
            android:shape="ring"
            android:innerRadius="48dp"
            android:thickness="1dp"
            android:useLevel="false">
            <solid android:color="#4DFF9500" /> <!-- 30% 불투명 -->
        </shape>
    </item>

    <!-- 2. 게이지 배경 원 (은은하게 깔리는 길) -->
    <!-- 패딩 대신 innerRadius를 조절해서 간격을 만듭니다. -->
    <item>
        <shape
            android:shape="ring"
            android:innerRadius="40dp"
            android:thickness="5dp"
            android:useLevel="false">
            <solid android:color="#26FF9500" /> <!-- 15% 불투명 -->
        </shape>
    </item>

    <!-- 3. 실시간으로 차오르는 진한 게이지 (뾰족함 방지) -->
    <item android:id="@android:id/progress">
        <rotate
            android:fromDegrees="270"
            android:pivotX="50%"
            android:pivotY="50%"
            android:toDegrees="270">
            <shape
                android:shape="ring"
                android:innerRadius="40dp"
                android:thickness="5.1dp"
                android:useLevel="true">
                <solid android:color="#FFFF9500" />
            </shape>
        </rotate>
    </item>
</layer-list>