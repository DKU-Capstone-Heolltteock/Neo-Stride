<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- 모드 선택 화면 (오늘의 코칭 목표가 있을 때만 표시) -->
    <ScrollView
        android:id="@+id/layout_mode_picker"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:visibility="gone"
        app:boxedEdges="all">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:minHeight="160dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘의 목표"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:letterSpacing="0.1"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tv_goal_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--.- km"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FF9500"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tv_goal_time_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:-- 이내"
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="14dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/btn_free_run"
                android:layout_width="120dp"
                android:layout_height="36dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="#CCFF00"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="자유 러닝"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/btn_coaching_run"
                android:layout_width="120dp"
                android:layout_height="36dp"
                app:cardBackgroundColor="#FF9500"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="오늘의 목표"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- 측정 중 화면 -->
    <ScrollView
        android:id="@+id/layout_running"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        app:boxedEdges="all">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:minHeight="160dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="거리"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/tv_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#CCFF00" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="km"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="4dp" />

            <!-- 코칭 모드: 남은 거리 표시 (자유 러닝 시 gone) -->
            <TextView
                android:id="@+id/tv_coaching_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="목표까지 -.- km"
                android:textSize="12sp"
                android:textColor="#FF9500"
                android:layout_marginBottom="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_pace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--'--&quot;/km"
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="16dp" />

            <!-- 일시정지/재개 버튼 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_toggle"
                android:layout_width="100dp"
                android:layout_height="40dp"
                app:cardBackgroundColor="#CCFF00"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">
                <TextView
                    android:id="@+id/tv_btn_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="시작"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- 코칭 미달 중단 경고 화면 -->
    <ScrollView
        android:id="@+id/layout_stop_warning"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:visibility="gone"
        app:boxedEdges="all">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:minHeight="160dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️ 목표 미달성"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FF4444"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기록이 저장되지 않습니다.\n종료할까요?"
                android:textSize="12sp"
                android:textColor="#CCCCCC"
                android:gravity="center"
                android:layout_marginBottom="14dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/btn_warning_stop"
                android:layout_width="110dp"
                android:layout_height="34dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="#FF4444"
                app:cardCornerRadius="17dp"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="종료"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/btn_warning_cancel"
                android:layout_width="110dp"
                android:layout_height="34dp"
                app:cardBackgroundColor="#333333"
                app:cardCornerRadius="17dp"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="계속 달리기"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- 카운트다운 / GPS 확보 대기 화면 -->
    <ScrollView
        android:id="@+id/layout_countdown"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:visibility="gone"
        app:boxedEdges="all">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:minHeight="160dp">

            <TextView
                android:id="@+id/tv_countdown_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="준비..."
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_countdown_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textSize="64sp"
                android:textStyle="bold"
                android:textColor="#CCFF00"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/btn_countdown_cancel"
                android:layout_width="90dp"
                android:layout_height="32dp"
                app:cardBackgroundColor="#333333"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="취소"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- 완료 화면 -->
    <ScrollView
        android:id="@+id/layout_result"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:visibility="gone"
        app:boxedEdges="all">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#121212"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:minHeight="160dp">

            <!-- 자유 러닝: "측정 완료" / 코칭 모드: "목표 달성!" -->
            <TextView
                android:id="@+id/tv_result_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="측정 완료"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#CCFF00"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_result_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tv_result_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="#AAAAAA" />

            <TextView
                android:id="@+id/tv_result_pace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#CCFF00"
                android:layout_marginBottom="14dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/btn_result_confirm"
                android:layout_width="90dp"
                android:layout_height="36dp"
                app:cardBackgroundColor="#CCFF00"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="확인"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.wear.widget.BoxInsetLayout>