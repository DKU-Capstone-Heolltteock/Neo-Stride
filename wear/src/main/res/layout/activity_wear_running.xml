<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- 측정 중 화면 -->
    <LinearLayout
        android:id="@+id/layout_running"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="거리"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/tv_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#CCFF00" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="km"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_pace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--&apos;--&quot;/km"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="16dp" />

        <!-- 시작/정지 버튼 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_toggle"
            android:layout_width="100dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="#CCFF00"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <TextView
                android:id="@+id/tv_btn_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="시작"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- 완료 화면 -->
    <LinearLayout
        android:id="@+id/layout_result"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#121212"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="측정 완료"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#CCFF00"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_result_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tv_result_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="#AAAAAA" />

        <TextView
            android:id="@+id/tv_result_pace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#CCFF00"
            android:layout_marginBottom="14dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_result_confirm"
            android:layout_width="90dp"
            android:layout_height="36dp"
            app:cardBackgroundColor="#CCFF00"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="확인"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.wear.widget.BoxInsetLayout>